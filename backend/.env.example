# Copy to .env for local dev. On Railway, set these in the dashboard.
ENVIRONMENT=development
PORT=8000

# Auth — must match your Lovable Cloud (Supabase) project
SUPABASE_URL=https://ztllrzlkdnlxjipxmhff.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
JWT_SECRET=change-me-to-a-long-random-string

# AI — RECOMMENDED: just set LOVABLE_API_KEY (one key, all models, no signup)
# Get it from: Lovable → your project → Connectors → Lovable AI → Copy key
LOVABLE_API_KEY=

# Optional fallbacks (only needed if you don't set LOVABLE_API_KEY)
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Storage
DATABASE_URL=postgresql+asyncpg://discoverse:discoverse@postgres:5432/discoverse
REDIS_URL=redis://redis:6379/0

# Optional vector memory
WEAVIATE_URL=
WEAVIATE_API_KEY=
